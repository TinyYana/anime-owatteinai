{
  "name": "anime-owatteinai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "追番進行式 — a private, application-gated anime watch-tracker for the 彼岸花 Discord community.",
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "vite",
    "build": "vite build",
