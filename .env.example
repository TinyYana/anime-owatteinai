# Neon Postgres connection string (pooled). Used by the Worker at runtime and by drizzle-kit.
DATABASE_URL=

# Discord OAuth2 application credentials (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8787/api/auth/discord/callback

# Random high-entropy string used to sign session + OAuth state cookies (HMAC-SHA256).
# Generate: openssl rand -hex 32
SESSION_SECRET=

# Comma-separated Discord user IDs that become "owner" automatically on first login.
ADMIN_DISCORD_IDS=

# Public base URL of the app (used to build OAuth redirects). Matches DISCORD_REDIRECT_URI host.
APP_BASE_URL=http://localhost:8787
